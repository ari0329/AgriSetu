# Flask Configuration
FLASK_ENV=production
PORT=5000
BASE_URL=https://your-app.onrender.com
SECRET_KEY=your-secret-key-here-change-this

# Twilio Credentials (Get from Twilio Console)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ThingESP Configuration
THINGESP_USERNAME=Noctum
THINGESP_PROJECT=Agrisetu
THINGESP_TOKEN=your_thingesp_token_here
THINGESP_API_URL=https://thingesp.com/api/users/Noctum/projects/Agrisetu/webhooks/twilio

# Trigger Keywords (comma-separated)
TRIGGER_KEYWORDS=prediction,predict,crop,report,recommend

# Logging
LOG_LEVEL=INFO